{
  "manifest_version": 3,
  "name": "Discord Translator",
  "description": "Traducción automática para Discord Web",
  "version": "1.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    },
    "default_title": "Discord Translator"
  },
  "permissions": ["storage", "unlimitedStorage"],
  "host_permissions": [
    "https://*.discord.com/*",
    "https://translate.googleapis.com/*"
  ],
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://*.discord.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}